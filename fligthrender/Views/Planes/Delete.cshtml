@model fligthrender.Models.Plane

@{
    ViewData["Title"] = "Delete";
}

<div class="container tm-mt-big">
    <div class="tm-block tm-block-settings">
        <h1 class="tm-block-title text-center">@ViewData["Title"]</h1>
        <h3 class="tm-small text-center">Вы уверены, что хотите удалить этот самолёт?</h3>
        <hr />

        <dl class="row">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Model)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Model)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Speed)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Speed)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Weight)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Weight)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Price)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Price)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Year)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Year)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Brand)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.Brand.BrandId)</dd>
        </dl>

        <!-- Кнопки действий -->
        <form asp-action="Delete" class="d-flex justify-content-between tm-mt-big">
            <input type="hidden" asp-for="PlaneId" />
            <button type="submit" class="btn btn-primary">🗑 Удалить</button>
            <a asp-action="Index" class="btn btn-primary">← Назад к списку</a>
        </form>
    </div>
</div>
