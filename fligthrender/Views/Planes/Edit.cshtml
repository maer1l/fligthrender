@model fligthrender.ViewModels.PlaneWithPhoto

@{
    ViewData["Title"] = "Edit";
}

<div class="container tm-mt-big">
    <div class="tm-block tm-block-settings">
        <h1 class="tm-block-title text-center">@ViewData["Title"]</h1>
        <h4 class="tm-small">Plane</h4>
        <hr />

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="plane.PlaneId" />
            <input type="hidden" name="hid" asp-for="plane.PlaneId" />

            <div class="form-group">
                <label asp-for="plane.Model"></label>
                <input asp-for="plane.Model" class="form-control" />
                <span asp-validation-for="plane.Model" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="plane.Speed"></label>
                <input asp-for="plane.Speed" class="form-control" />
                <span asp-validation-for="plane.Speed" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="plane.Weight"></label>
                <input asp-for="plane.Weight" class="form-control" />
                <span asp-validation-for="plane.Weight" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="plane.Price"></label>
                <input asp-for="plane.Price" class="form-control" />
                <span asp-validation-for="plane.Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="plane.Year"></label>
                <input asp-for="plane.Year" class="form-control" />
                <span asp-validation-for="plane.Year" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="plane.BrandId"></label>
                <select asp-for="plane.BrandId" class="custom-select" asp-items="ViewBag.BrandId"></select>
                <span asp-validation-for="plane.BrandId" class="text-danger"></span>
            </div>

            <div class="form-group tm-mt-small">
                <input type="submit" value="Сохранить" class="btn btn-primary"/>
            </div>
        </form>

        <div class="tm-block tm-block-avatar tm-mt-small">
            <h2 class="tm-block-title">Фотографии</h2>
            <div id="resultimg" class="row">
                @foreach (var path in Model.paths)
                {
                    <div class="col-md-4 tm-product-img-edit text-center" style="margin-bottom:20px;">
                        <img src="@path" alt="Plane photo"
                             style="width:100%; height:200px; object-fit:cover;" />
                        <form asp-action="DeletePhoto" asp-controller="Planes" method="post" data-ajax="delete-photo" style="margin-top:10px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="photoPath" value="@path" />
                            <input type="hidden" name="planeId" value="@Model.plane.PlaneId" />
                            <button type="submit" class="btn btn-primary btn-small">
                                Удалить
                            </button>
                        </form>
                    </div>
                }
                <div class="col-md-4 text-center" style="margin-bottom:20px;">
                    <label for="files" style="
                display:flex;
                align-items:center;
                justify-content:center;
                width:100%;
                height:200px;
                border:2px dashed #f5a623;
                cursor:pointer;
                font-size:48px;
                color:#f5a623;">
                        +
                    </label>
                </div>
            </div>
        </div>

        <form id="form" name="form" action="/UploadFiles" enctype="multipart/form-data" method="post" style="display:none;">
            @Html.AntiForgeryToken()
            <input id="files" name="files" type="file" size="1" multiple />
        </form>



        @* <form id="form" name="form" action="/UploadFiles" enctype="multipart/form-data" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(model => model.files, htmlAttributes: new { @class = "control-label" })
                <input id="files" name="files" type="file" size="1" multiple />
                @Html.ValidationMessageFor(model => model.files, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <input id="submit" type="submit" value="Upload" class="btn btn-primary" />
            </div>
            <div class="form-group">
                <div class="text-success">
                    @ViewBag.UploadStatus
                </div>
            </div>
        </form> *@



        <div class="tm-mt-small">
            <a asp-action="Index" class="btn btn-primary">← Назад к списку</a>
        </div>
    </div>
</div>

<script>
        $(document).on("submit", "form[data-ajax='delete-photo']", function (e) {
        e.preventDefault(); 

        var form = $(this);
        var photoDiv = form.closest(".tm-product-img-edit");

        $.ajax({
            url: form.attr("action"),
            type: "POST",
            data: form.serialize(),
            dataType: "json",
            success: function () {
                
                photoDiv.remove();
            },
            error: function (err) {
                console.log("Ошибка при удалении фото:", err);
            }
        });
    });


            function appendPhotos(paths) {
        var container = $("#resultimg");
        container.empty();

        var token = $('input[name="__RequestVerificationToken"]').val();
        var planeId = $('input[name="hid"]').val();

        for (var i = 0; i < paths.length; i++) {
            var photoDiv = $('<div class="col-md-4 tm-product-img-edit text-center" style="margin-bottom:20px;">');

            var img = $('<img>')
                .attr('src', paths[i])
                .attr('alt', 'Plane photo')
                .css({ width: '100%', height: '200px', objectFit: 'cover' });

            var form = $('<form>', {
                method: 'post',
                action: '@Url.Action("DeletePhoto", "Planes")',
                style: 'margin-top:10px;',
                'data-ajax': 'delete-photo'
            })
            .append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: token }))
            .append($('<input>', { type: 'hidden', name: 'photoPath', value: paths[i] }))
            .append($('<input>', { type: 'hidden', name: 'planeId', value: planeId }))
            .append($('<button>', { type: 'submit', class: 'btn btn-primary btn-small', text: 'Удалить' }));

            photoDiv.append(img).append(form);
            container.append(photoDiv);
        }

        
        var plusDiv = $('<div class="col-md-4 text-center" style="margin-bottom:20px;">')
            .append($('<label>', {
                for: 'files',
                text: '+',
                style: 'display:flex;align-items:center;justify-content:center;width:100%;height:200px;border:2px dashed #f5a623;cursor:pointer;font-size:48px;color:#f5a623;'
            }));
        container.append(plusDiv);
    }




        $(document).ready(function () {
        $('#files').on('change', function () {
            var input = document.getElementById('files');
            var files = input.files;

            var formData = new FormData();
            var val = document.getElementsByName("__RequestVerificationToken")[0].value;
            var planeId = document.getElementsByName("hid")[0].value;

            formData.append("__RequestVerificationToken", val);
            formData.append("plane.PlaneId", planeId);

            for (var i = 0; i < files.length; i++) {
                formData.append("files", files[i]);
            }

            $.ajax({
                url: '@Url.Action("UploadFiles", "Planes")',
                data: formData,
                processData: false,
                contentType: false,
                type: "POST",
                success: function (data) {
                    console.log(data);
                    appendPhotos(data);
                },
                error: function (data) {
                    console.log(data);
                }
            });
        });
    });
</script>

