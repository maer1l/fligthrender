@model fligthrender.ViewModels.PlaneWithPhoto

@{
    ViewData["Title"] = "Details";
}

<div class="container tm-mt-big">
    <div class="tm-block tm-block-settings">
        <h1 class="tm-block-title text-center">@ViewData["Title"]</h1>

        <carousel paths="@Model.paths" />
        <hr />

        <h4 class="tm-block-title">Plane</h4>

        <dl class="row tm-list">
            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Model)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Model)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Speed)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Speed)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Weight)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Weight)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Price)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Price)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Year)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Year)</dd>

            <dt class="col-sm-2">@Html.DisplayNameFor(model => model.plane.Brand)</dt>
            <dd class="col-sm-10 tm-text-color-secondary">@Html.DisplayFor(model => model.plane.Brand.BrandId)</dd>
        </dl>

        <div class="d-flex justify-content-between tm-mt-big">
            <a asp-action="Edit" asp-route-id="@Model?.plane.PlaneId" class="btn btn-primary">✏️ Edit</a>
            <a asp-action="Index" class="btn btn-primary">← Back to List</a>
        </div>
    </div>
</div>
