@{
    ViewData["Title"] = "Flights";
}

<h2>Flights</h2>

<table id="flightsTable" class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>flight number</th>
            <th>direction</th>
            <th>gate number</th>
            <th>people count</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<input type="button" id="show" value="Show" />

<script>
    $('#show').click(function (e) {
        $.ajax({
            url: 'http://2.26.51.183/api/Flights/',
            method: "GET",
            dataType: 'JSON',
            contentType: 'application/json',
            cache: false,
            processData: false,
            success: function (data) {
                console.log(data);
                let table = $('#flightsTable');
                table.find("tbody tr").remove();

                data.forEach(function(flight){
                    table.append("<tr><td>" +
                    flight.flightNumber + "</td>" +
                    "<td>" + flight.direction + "</td>" +
                    "<td>" + flight.gateNumber + "</td>" +
                    "<td>" + flight.peopleCount + "</td></tr>");
                });
            },
            error: function(xhr, status, error) {
                alert("Error: " + xhr.status + " | " + xhr.responseText);
                console.log(xhr);
            }
        })
    });

</script>