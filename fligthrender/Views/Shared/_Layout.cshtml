                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Planes" asp-action="Index">
                                <i class="far fa-file-alt"></i>
                                <span>
                                    Planes
                                </span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Manufacturers" asp-action="Index">
